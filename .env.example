NODE_ENV=production
LOG_LEVEL=info
BOT_TOKEN=
PORT=3000
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=alyona_bot
# Comma-separated Telegram user IDs of the owner(s) — gets full permissions on first /start
OWNER_TG_IDS=
# LiqPay provider token from BotFather (TG Payments → LiqPay)
LIQPAY_PROVIDER_TOKEN=
LIQPAY_TEST_MODE=true
# 64 hex chars (32 bytes) — generate with: openssl rand -hex 32
MASTER_KEY=
SENTRY_DSN=

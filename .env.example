NODE_ENV=production
LOG_LEVEL=info

# === Telegram ===
BOT_TOKEN=
# Comma-separated Telegram user IDs of the owner(s) — gets full permissions on first /start
OWNER_TG_IDS=

# === Payments ===
# LiqPay provider token from BotFather (TG Payments → LiqPay)
LIQPAY_PROVIDER_TOKEN=
LIQPAY_TEST_MODE=true

# === Network ===
PORT=3000
# In compose, leave as 'mongodb://mongo:27017'. For local dev: mongodb://localhost:27017
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=alyona_bot

# === Secrets ===
# 64 hex chars (32 bytes) — generate with: openssl rand -hex 32
MASTER_KEY=

# === Optional ===
SENTRY_DSN=
NBU_API_URL=https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange?valcode=USD&json

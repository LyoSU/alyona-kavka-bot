{
  "name": "alyona-kavka-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/bundle.cjs",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "migrate-mongo",
    "seed": "tsx seed/run.ts"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/files": "^1.2.0",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/storage-mongodb": "^2.5.1",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@hono/node-server": "^2.0.2",
    "@sentry/node": "^10.53.1",
    "grammy": "^1.43.0",
    "hono": "^4.12.19",
    "libsodium-wrappers": "^0.8.4",
    "mongodb": "^7.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@testcontainers/mongodb": "^11.14.0",
    "@types/node": "^24.0.0",
    "migrate-mongo": "^14.0.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
